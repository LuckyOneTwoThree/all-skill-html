{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "page-manifest",
  "description": "页面清单——编排器生成的统一页面清单，防止页面遗漏",
  "type": "object",
  "required": ["manifest_id", "generated_at", "source", "pages"],
  "properties": {
    "manifest_id": {"type": "string"},
    "generated_at": {"type": "string"},
    "source": {"type": "string", "description": "页面清单来源（prd.json / ia_proposals.json / both / user_input）"},
    "pages": {
      "type": "array",
      "description": "必须生成的页面清单",
      "items": {
        "type": "object",
        "required": ["page_id", "name", "route"],
        "properties": {
          "page_id": {"type": "string", "description": "页面唯一标识（来自prd.json）"},
          "name": {"type": "string", "description": "页面名称"},
          "route": {"type": "string", "description": "路由路径"},
          "description": {"type": "string", "description": "页面功能描述"},
          "functional_areas": {"type": "array", "items": {"type": "string"}, "description": "必须覆盖的功能区域"},
          "depth": {"type": "integer", "description": "导航层级深度（来自ia_proposals）"},
          "cross_validated": {"type": "boolean", "description": "是否经过prd.json与ia_proposals交叉校验"}
        }
      }
    },
    "cross_validation_issues": {
      "type": "array",
      "description": "交叉校验发现的不一致",
      "items": {
        "type": "object",
        "properties": {
          "type": {"type": "string", "enum": ["missing_in_prd", "missing_in_ia", "route_mismatch", "name_mismatch"]},
          "prd_value": {"type": "string"},
          "ia_value": {"type": "string"},
          "resolution": {"type": "string", "description": "消解策略（以prd为准/以ia为准/需人类确认）"}
        }
      }
    }
  }
}
